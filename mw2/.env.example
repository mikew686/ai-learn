# Copy to .env in this directory (mw2/). Used by app, rqworker, and alembic when run from mw2/.
# These match the defaults in src/config/settings.py.

# Flask app config (loaded into app.config). FLASK_ENV/FLASK_DEBUG control server mode;
# SECRET_KEY must be a fixed random value in production (sessions/CSRF break if it changes on restart).
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-in-production

# Database (defaults = local Postgres after port-forward or LoadBalancer)
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=localdev
# PGDATABASE=postgres
# Or set DATABASE_URL to override.
# DATABASE_CONNECT_TIMEOUT=5
# DATABASE_POOL_RECYCLE=300

# Gunicorn (Docker/default CMD: workers, bind, timeout, log-level)
# GUNICORN_WORKERS=4
# GUNICORN_BIND=0.0.0.0:8000
# GUNICORN_TIMEOUT=30
# GUNICORN_LOG_LEVEL=info

# RQ worker debug logging
# RQ_DEBUG=1

# Redis (default = local)
# REDIS_URL=redis://localhost:6379/0
# REDIS_SOCKET_TIMEOUT=5
# REDIS_SOCKET_CONNECT_TIMEOUT=5
# REDIS_HEALTH_CHECK_INTERVAL=30
