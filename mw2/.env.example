# Copy to .env in this directory (mw2/). Used by app, rqworker, and alembic when run from mw2/.

# Flask vs Gunicorn: FLASK_* and SECRET_KEY apply to the app itself (create_app) and are used by both
# the dev server (python -m app) and Gunicorn in Docker. GUNICORN_* applies only when the app is
# served by Gunicorn (Docker or gunicorn CLI); FLASK_HOST/FLASK_PORT/FLASK_DEBUG apply only to the
# dev server (python -m app). In Docker, set FLASK_ENV, SECRET_KEY, etc. via runtime env or k8s.

# Flask app config. FLASK_ENV and SECRET_KEY must be set explicitly (no command-line override).
FLASK_ENV=development
SECRET_KEY=change-me-in-production

# Debug server (python -m app) only
# Dev server host (sdk: 127.0.0.1; default: 0.0.0.0)
#FLASK_HOST=0.0.0.0
# Dev server port (sdk: 5000; default: 5000)
#FLASK_PORT=5000
# Enable debug mode and reloader (default: 1)
#FLASK_DEBUG=1

# Gunicorn (Docker/default CMD: workers, bind, timeout, log-level)
# Apply to Docker builds only.
# GUNICORN_WORKERS=4
# GUNICORN_BIND=0.0.0.0:8000
# GUNICORN_TIMEOUT=30
# GUNICORN_LOG_LEVEL=info

# Database connection URL (sdk: create_engine requires URL; our default: built from PG* when unset)
#DATABASE_URL=
# Postgres host when DATABASE_URL unset (sdk: n/a; default: localhost)
#PGHOST=localhost
# Postgres port when DATABASE_URL unset (sdk: n/a; default: 5432)
#PGPORT=5432
# Postgres user when DATABASE_URL unset (sdk: n/a; default: postgres)
#PGUSER=postgres
# Postgres password when DATABASE_URL unset (sdk: n/a; default: localdev)
#PGPASSWORD=localdev
# Postgres database name when DATABASE_URL unset (sdk: n/a; default: postgres)
#PGDATABASE=postgres

# SQLAlchemy database URL for Postgres connection (default: none)
#DATABASE_URL=postgresql+psycopg://postgresd@localhost:5432/appdb
# Connection timeout in seconds for initial database connection (default: driver default, commonly 10)
#DATABASE_CONNECT_TIMEOUT=10
# Enable pool pre-ping to test stale connections before use (default: false)
#DATABASE_POOL_PRE_PING=false
# Recycle pooled connections after this many seconds (default: -1, disabled)
#DATABASE_POOL_RECYCLE=-1
# Number of persistent connections kept in the pool (default: 5)
#DATABASE_POOL_SIZE=5
# Number of extra connections allowed above pool_size (default: 10)
#DATABASE_MAX_OVERFLOW=10
# Seconds to wait for a pooled connection before timing out (default: 30)
#DATABASE_POOL_TIMEOUT=30
# Reuse the most recently returned connection first (default: false)
#DATABASE_POOL_USE_LIFO=false
# Enable SQLAlchemy SQL logging (default: false)
#DATABASE_ECHO=false
# Enable verbose pool logging (default: false)
#DATABASE_ECHO_POOL=false
# Action when a connection is returned to the pool: rollback | commit | none (default: rollback)
#DATABASE_POOL_RESET_ON_RETURN=rollback
# Transaction isolation level for new connections (default: driver/database default)
#DATABASE_ISOLATION_LEVEL=
# Client encoding for the database connection (default: driver/database default)
#DATABASE_CLIENT_ENCODING=
# Application name reported to Postgres sessions (default: none)
#DATABASE_APPLICATION_NAME=

# Redis connection URL (sdk: from_url requires URL; our default: built from host/port/db when unset)
#REDIS_URL=
# Redis host when REDIS_URL unset (sdk: n/a; default: localhost)
#REDIS_HOST=localhost
# Redis port when REDIS_URL unset (sdk: n/a; default: 6379)
#REDIS_PORT=6379
# Redis database number when REDIS_URL unset (sdk: n/a; default: 0)
#REDIS_DB=0
# Socket timeout in seconds for Redis operations (default: none)
#REDIS_SOCKET_TIMEOUT=
# Timeout in seconds for establishing a Redis connection (default: none)
#REDIS_SOCKET_CONNECT_TIMEOUT=
# Enable TCP keepalive on Redis socket (default: false)
#REDIS_SOCKET_KEEPALIVE=false
# Interval in seconds for Redis connection health checks (default: 0)
#REDIS_HEALTH_CHECK_INTERVAL=0
# Retry commands automatically on timeout (default: false)
#REDIS_RETRY_ON_TIMEOUT=false
# Automatically decode Redis responses to strings instead of bytes (default: false)
#REDIS_DECODE_RESPONSES=false
# Redis protocol version to use (2 or 3) (default: 2)
#REDIS_PROTOCOL=2
# Optional client name shown in Redis CLIENT LIST (default: none)
#REDIS_CLIENT_NAME=
# Enable TLS/SSL connection to Redis (default: false)
#REDIS_SSL=false
# Path to TLS client certificate file (default: none)
#REDIS_SSL_CERTFILE=
# Path to TLS client private key file (default: none)
#REDIS_SSL_KEYFILE=
# Path to TLS CA certificate bundle (default: none)
#REDIS_SSL_CA_CERTS=
# TLS certificate verification requirement (none, optional, required) (default: required)
#REDIS_SSL_CERT_REQS=required

# Queue name the worker should consume from (default: default)
#RQ_QUEUE_NAME=default
# Explicit worker name for the worker process (default: auto-generated by RQ)
#RQ_WORKER_NAME=
# Whether the queue executes jobs asynchronously (default: true)
#RQ_IS_ASYNC=true
# Default job timeout in seconds before the worker aborts the job (default: 180)
#RQ_DEFAULT_TIMEOUT=180
# How long job results are kept in Redis in seconds (default: 500)
#RQ_RESULTS_TTL=500
# Maximum number of jobs the worker will process before exiting (default: unlimited)
#RQ_MAX_JOBS=
# Maximum idle time in seconds before the worker exits (default: unlimited)
#RQ_MAX_IDLE_TIME=
# Disable built-in RQ scheduler (default: false)
#RQ_DISABLE_SCHEDULER=false
# Strategy used when consuming from multiple queues: default | random | round_robin (default: default)
#RQ_DEQUEUE_STRATEGY=default
# Interval in seconds between worker maintenance tasks (default: 600)
#RQ_MAINTENANCE_INTERVAL=600
# Logging level used by the RQ worker (default: INFO)
#RQ_LOGGING_LEVEL=INFO
# Log message format used by the worker (default: %(asctime)s %(levelname)s %(message)s)
#RQ_LOG_FORMAT=%(asctime)s %(levelname)s %(message)s
# Timestamp format used in worker logs (default: %H:%M:%S)
#RQ_DATE_FORMAT=%H:%M:%S
# Custom serializer class used by RQ (default: rq.serializers.DefaultSerializer)
#RQ_SERIALIZER=rq.serializers.DefaultSerializer
# Custom job class used by the worker (default: rq.job.Job)
#RQ_JOB_CLASS=rq.job.Job
# Custom queue class used by the worker (default: rq.queue.Queue)
#RQ_QUEUE_CLASS=rq.queue.Queue

# OpenRouter API
# API key (required for AI features)
#OPENROUTER_API_KEY=your-openrouter-api-key
# Base URL (sdk: OpenAI default; default: https://openrouter.ai/api/v1)
#OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Request timeout in seconds (sdk: 600; default: none, use SDK)
#OPENROUTER_TIMEOUT=600
# Max retries for transient errors (sdk: 2; default: none, use SDK)
#OPENROUTER_MAX_RETRIES=2

