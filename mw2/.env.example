# Copy to .env in this directory (mw2/). Used by app, rqworker, and alembic when run from mw2/.
# These match the defaults in src/config/settings.py.

FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-in-production

# Database (defaults = local Postgres after port-forward or LoadBalancer)
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=localdev
# PGDATABASE=postgres
# Or set DATABASE_URL to override.
# DATABASE_CONNECT_TIMEOUT=5
# DATABASE_POOL_RECYCLE=300

# RQ worker debug logging
# RQ_DEBUG=1

# Redis (default = local)
# REDIS_URL=redis://localhost:6379/0
# REDIS_SOCKET_TIMEOUT=5
# REDIS_SOCKET_CONNECT_TIMEOUT=5
# REDIS_HEALTH_CHECK_INTERVAL=30
