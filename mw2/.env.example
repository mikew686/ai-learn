# Copy to .env in this directory (mw2/). Used by app, rqworker, and alembic when run from mw2/.

# Flask vs Gunicorn: FLASK_* and SECRET_KEY apply to the app itself (create_app) and are used by both
# the dev server (python -m app) and Gunicorn in Docker. GUNICORN_* applies only when the app is
# served by Gunicorn (Docker or gunicorn CLI); FLASK_HOST/FLASK_PORT apply only to the dev server.
# In Docker, set SECRET_KEY, FLASK_DEBUG, etc. via runtime env or k8s.

# Flask app config (Flask 3.1+). SECRET_KEY must be set explicitly.
# FLASK_ENV was removed in Flask 2.3; use FLASK_DEBUG for dev mode.
SECRET_KEY=change-me-in-production
# Debug mode (default: 0)
#FLASK_DEBUG=0
# Testing mode for pytest etc (default: 0)
#FLASK_TESTING=0
# Max request body size in bytes (sdk: none; default: none)
#FLASK_MAX_CONTENT_LENGTH=16777216
# Session cookie secure for HTTPS (default: 0)
#FLASK_SESSION_COOKIE_SECURE=0
# Session cookie SameSite: Lax | Strict | None (default: none)
#FLASK_SESSION_COOKIE_SAMESITE=Lax
# URL scheme for url_for outside request (default: http)
#FLASK_PREFERRED_URL_SCHEME=http
# Comma-separated trusted hosts (default: none)
#FLASK_TRUSTED_HOSTS=

# Debug server (python -m app) only
# Dev server host (sdk: 127.0.0.1; default: 0.0.0.0)
#FLASK_HOST=0.0.0.0
# Dev server port (sdk: 5000; default: 5000)
#FLASK_PORT=5000
# Enable debug mode and reloader (default: 1)
#FLASK_DEBUG=1

# Gunicorn (25.1.0, Docker CMD only)
# Env vars used by mw2.Dockerfile CMD; override at runtime: docker run -e GUNICORN_WORKERS=8
# workers (sdk: 1; default: 4)
#GUNICORN_WORKERS=4
# bind address:port (sdk: 127.0.0.1:8000; default: 0.0.0.0:8000)
#GUNICORN_BIND=0.0.0.0:8000
# timeout seconds (sdk: 30; default: 30)
#GUNICORN_TIMEOUT=30
# log-level: debug|info|warning|error|critical (sdk: info; default: info)
#GUNICORN_LOG_LEVEL=info

# Database (SQLAlchemy 2.0.46, psycopg2-binary 2.9.11)
# Connection URL (sdk: create_engine requires URL; our default: built from PG* when unset)
#DATABASE_URL=
# Postgres host when DATABASE_URL unset (sdk: n/a; default: localhost)
#PGHOST=localhost
# Postgres port when DATABASE_URL unset (sdk: n/a; default: 5432)
#PGPORT=5432
# Postgres user when DATABASE_URL unset (sdk: n/a; default: postgres)
#PGUSER=postgres
# Postgres password when DATABASE_URL unset (sdk: n/a; default: localdev)
#PGPASSWORD=localdev
# Postgres database name when DATABASE_URL unset (sdk: n/a; default: postgres)
#PGDATABASE=postgres

# SQLAlchemy 2.0 + psycopg2-binary: use postgresql:// or postgresql+psycopg2:// (default: none)
#DATABASE_URL=postgresql+psycopg2://postgres:localdev@localhost:5432/postgres
# psycopg2 connect_timeout in seconds (default: none)
#DATABASE_CONNECT_TIMEOUT=10
# SQLAlchemy engine/pool params (2.0.46)
# pool_pre_ping tests connections before use (default: none)
#DATABASE_POOL_PRE_PING=false
# pool_recycle seconds (-1 disabled) (sdk: -1; default: none)
#DATABASE_POOL_RECYCLE=-1
# pool_size persistent connections (sdk: 5; default: none)
#DATABASE_POOL_SIZE=5
# max_overflow extra connections above pool_size (sdk: 10; default: none)
#DATABASE_MAX_OVERFLOW=10
# pool_timeout seconds to wait for connection (sdk: 30; default: none)
#DATABASE_POOL_TIMEOUT=30
# Reuse the most recently returned connection first (default: false)
#DATABASE_POOL_USE_LIFO=false
# Enable SQLAlchemy SQL logging (default: false)
#DATABASE_ECHO=false
# Enable verbose pool logging (default: false)
#DATABASE_ECHO_POOL=false
# Action when a connection is returned to the pool: rollback | commit | none (default: rollback)
#DATABASE_POOL_RESET_ON_RETURN=rollback
# Transaction isolation level for new connections (default: driver/database default)
#DATABASE_ISOLATION_LEVEL=
# psycopg2 client_encoding (default: none)
#DATABASE_CLIENT_ENCODING=
# psycopg2 application_name for Postgres sessions (default: none)
#DATABASE_APPLICATION_NAME=

# Redis (redis-py 7.2.0)
# Connection URL for Redis.from_url (sdk: required; our default: built from REDIS_HOST/PORT/DB when unset)
#REDIS_URL=
#REDIS_HOST=localhost
#REDIS_PORT=6379
#REDIS_DB=0
# redis-py: socket_timeout seconds (sdk: none; default: none)
#REDIS_SOCKET_TIMEOUT=
# redis-py: socket_connect_timeout seconds (sdk: none; default: none)
#REDIS_SOCKET_CONNECT_TIMEOUT=
# redis-py: socket_keepalive (sdk: none; default: none)
#REDIS_SOCKET_KEEPALIVE=false
# redis-py: health_check_interval seconds (sdk: 0; default: none)
#REDIS_HEALTH_CHECK_INTERVAL=0
# redis-py: retry_on_timeout (sdk: false; default: none)
#REDIS_RETRY_ON_TIMEOUT=false
# redis-py: decode_responses (sdk: false; default: none)
#REDIS_DECODE_RESPONSES=false
# redis-py: protocol 2 or 3 (sdk: 2; default: none)
#REDIS_PROTOCOL=2
# redis-py: client_name for CLIENT LIST (sdk: none; default: none)
#REDIS_CLIENT_NAME=
# redis-py TLS: ssl, ssl_certfile, ssl_keyfile, ssl_ca_certs, ssl_cert_reqs (required|optional|none)
#REDIS_SSL=false
#REDIS_SSL_CERTFILE=
#REDIS_SSL_KEYFILE=
#REDIS_SSL_CA_CERTS=
#REDIS_SSL_CERT_REQS=required

# RQ worker (rq 2.6.1)
# Queue name (sdk: default; default: none, RQ uses 'default')
#RQ_QUEUE_NAME=default
# Worker name (sdk: auto-generated; default: none)
#RQ_WORKER_NAME=
# Queue is_async (sdk: true; default: none)
#RQ_IS_ASYNC=true
# Queue default_timeout seconds (sdk: 180; default: none)
#RQ_DEFAULT_TIMEOUT=180
# Worker default_result_ttl / results-ttl seconds (sdk: 500; default: none)
#RQ_RESULTS_TTL=500
# work() max_jobs then exit (sdk: unlimited; default: none)
#RQ_MAX_JOBS=
# work() max_idle_time seconds then exit (sdk: unlimited; default: none)
#RQ_MAX_IDLE_TIME=
# work() with_scheduler; set RQ_DISABLE_SCHEDULER=1 to disable (sdk: false; default: scheduler enabled)
#RQ_DISABLE_SCHEDULER=false
# work() dequeue_strategy: default | random | round_robin (sdk: default; default: none)
#RQ_DEQUEUE_STRATEGY=default
# Worker maintenance_interval seconds (sdk: 600; default: none)
#RQ_MAINTENANCE_INTERVAL=600
# work() logging_level (sdk: INFO; default: INFO)
#RQ_LOGGING_LEVEL=INFO
# work() log_format (sdk: %(asctime)s %(message)s; default: %(asctime)s %(levelname)s %(message)s)
#RQ_LOG_FORMAT=%(asctime)s %(levelname)s %(message)s
# work() date_format (sdk: %H:%M:%S; default: %H:%M:%S)
#RQ_DATE_FORMAT=%H:%M:%S
# Serializer dotted path (sdk: rq.serializers.DefaultSerializer; default: none)
#RQ_SERIALIZER=rq.serializers.DefaultSerializer
# job_class dotted path (sdk: rq.job.Job; default: none)
#RQ_JOB_CLASS=rq.job.Job
# queue_class dotted path (sdk: rq.queue.Queue; default: none)
#RQ_QUEUE_CLASS=rq.queue.Queue

# OpenRouter API
# API key (required for AI features)
#OPENROUTER_API_KEY=your-openrouter-api-key
# Base URL (sdk: OpenAI default; default: https://openrouter.ai/api/v1)
#OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Request timeout in seconds (sdk: 600; default: none, use SDK)
#OPENROUTER_TIMEOUT=600
# Max retries for transient errors (sdk: 2; default: none, use SDK)
#OPENROUTER_MAX_RETRIES=2

